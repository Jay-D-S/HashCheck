<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HashCheck.Views.MirrorVerificationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:HashCheck.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Mirror Verification"
                   Style="{ThemeResource TitleTextBlockStyle}"
                   Margin="0,0,0,4"/>

        <!-- Subtitle: media name + new mirror label -->
        <TextBlock Grid.Row="1"
                   x:Name="SubtitleLabel"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,16"/>

        <!-- Content area -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" MaxWidth="640">

                <!-- ── In-progress: validation ── -->
                <StackPanel Visibility="{x:Bind ViewModel.IsInProgress, Mode=OneWay,
                                         Converter={StaticResource BoolToVisibility}}"
                            Spacing="12">
                    <TextBlock Text="{x:Bind ViewModel.PhaseHeading, Mode=OneWay}"
                               Style="{ThemeResource SubtitleTextBlockStyle}"/>

                    <!-- Validation phase: determinate progress -->
                    <StackPanel Visibility="{x:Bind ViewModel.IsValidating, Mode=OneWay,
                                             Converter={StaticResource BoolToVisibility}}"
                                Spacing="6">
                        <ProgressBar Value="{x:Bind ViewModel.FilesProcessed, Mode=OneWay}"
                                     Maximum="{x:Bind ViewModel.FilesTotal, Mode=OneWay}"/>
                        <TextBlock Text="{x:Bind ViewModel.ProgressFilesText, Mode=OneWay}"
                                   FontSize="12"/>
                        <ProgressBar Value="{x:Bind ViewModel.BytesProcessedD, Mode=OneWay}"
                                     Maximum="{x:Bind ViewModel.BytesTotalD, Mode=OneWay}"/>
                        <TextBlock Text="{x:Bind ViewModel.ProgressBytesText, Mode=OneWay}"
                                   FontSize="12"/>
                        <TextBlock Text="{x:Bind ViewModel.EtaText, Mode=OneWay}"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Analysis phase: determinate progress over corrupted-file subset -->
                    <StackPanel Visibility="{x:Bind ViewModel.IsAnalysing, Mode=OneWay,
                                             Converter={StaticResource BoolToVisibility}}"
                                Spacing="6">
                        <ProgressBar Value="{x:Bind ViewModel.AnalysisProgressD, Mode=OneWay}"
                                     Maximum="{x:Bind ViewModel.AnalysisTotalD, Mode=OneWay}"/>
                        <TextBlock Text="{x:Bind ViewModel.AnalysisProgressText, Mode=OneWay}"
                                   FontSize="12"/>
                        <TextBlock Text="{x:Bind ViewModel.AnalysisCurrentFile, Mode=OneWay}"
                                   FontSize="12" TextTrimming="CharacterEllipsis"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <TextBlock Text="{x:Bind ViewModel.CurrentFile, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.IsValidating, Mode=OneWay,
                                            Converter={StaticResource BoolToVisibility}}"
                               TextTrimming="CharacterEllipsis" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- ── All good ── -->
                <Border Visibility="{x:Bind ViewModel.IsAllGood, Mode=OneWay,
                                     Converter={StaticResource BoolToVisibility}}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="✓  All files verified"
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   Foreground="#2DB840"/>
                        <TextBlock x:Name="AllGoodDetail"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="WrapWholeWords"/>
                    </StackPanel>
                </Border>

                <!-- ── Cancelled ── -->
                <TextBlock Visibility="{x:Bind ViewModel.IsCancelled, Mode=OneWay,
                                        Converter={StaticResource BoolToVisibility}}"
                           Text="Verification was cancelled."
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <!-- ── Failed ── -->
                <StackPanel Visibility="{x:Bind ViewModel.IsFailed, Mode=OneWay,
                                         Converter={StaticResource BoolToVisibility}}"
                            Spacing="4">
                    <TextBlock Text="Verification failed" Foreground="#E81123"/>
                    <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- ── Complete: 50/50 case (mismatches, no other drives to compare) ── -->
                <StackPanel Visibility="{x:Bind ViewModel.Has50_50Case, Mode=OneWay,
                                         Converter={StaticResource BoolToVisibility}}"
                            Spacing="12">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="Fifty50Heading"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"
                                       Foreground="#F7630C"
                                       TextWrapping="WrapWholeWords"/>
                            <TextBlock Text="You only have 2 copies of this data. Without a third copy we cannot determine which is correct. Inspect the files manually before deciding."
                                       TextWrapping="WrapWholeWords"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="Fifty50FileList" TextWrapping="WrapWholeWords"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- ── Complete: majority-vote results ── -->
                <StackPanel Visibility="{x:Bind ViewModel.HasMajorityVote, Mode=OneWay,
                                         Converter={StaticResource BoolToVisibility}}"
                            Spacing="16">

                    <!-- New mirror corrupted -->
                    <StackPanel x:Name="CorruptedSection" Spacing="8">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="16">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="CorruptedHeading"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           Foreground="#E81123"/>
                                <TextBlock Text="Your other drives agree with the stored hashes. These files appear corrupted on the new mirror — likely silent bit-rot."
                                           TextWrapping="WrapWholeWords"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <ListView x:Name="CorruptedList"
                                  MaxHeight="200"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  FontSize="12"/>
                    </StackPanel>

                    <!-- Stored hash suspect -->
                    <StackPanel x:Name="SuspectSection" Spacing="8">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="16">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="SuspectHeading"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           Foreground="#F7630C"/>
                                <TextBlock Text="Your other drives all agree on a different hash value. The original hash set may have been created from a corrupted drive — consider re-baselining."
                                           TextWrapping="WrapWholeWords"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <ListView x:Name="SuspectList"
                                  MaxHeight="200"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  FontSize="12"/>
                    </StackPanel>

                    <!-- Indeterminate -->
                    <StackPanel x:Name="IndeterminateSection" Spacing="8">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="16">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="IndeterminateHeading"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           Foreground="#C19C00"/>
                                <TextBlock Text="Every copy has different data for these files. Manual inspection is required."
                                           TextWrapping="WrapWholeWords"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <ListView x:Name="IndeterminateList"
                                  MaxHeight="200"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  FontSize="12"/>
                    </StackPanel>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Action bar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
            <Button x:Name="CancelBtn"
                    Content="Cancel"
                    Click="Cancel_Click"
                    Visibility="{x:Bind ViewModel.IsInProgress, Mode=OneWay,
                                  Converter={StaticResource BoolToVisibility}}"/>
            <Button x:Name="RepairBtn"
                    Content="Repair new mirror"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="Repair_Click"
                    Visibility="{x:Bind ViewModel.IsDone, Mode=OneWay,
                                  Converter={StaticResource BoolToVisibility}}"
                    IsEnabled="{x:Bind ViewModel.CanRepair, Mode=OneWay}"
                    ToolTipService.ToolTip="Navigate to Repair to copy intact files from your other drives to the new mirror."/>
            <Button x:Name="RebaselineBtn"
                    Content="Re-baseline from scratch"
                    Click="Rebaseline_Click"
                    Visibility="{x:Bind ViewModel.IsDone, Mode=OneWay,
                                  Converter={StaticResource BoolToVisibility}}"
                    ToolTipService.ToolTip="Discard stored hashes and re-hash all files from a chosen volume."/>
            <Button x:Name="MediaGroupBtn"
                    Content="Go to Media Group"
                    Click="MediaGroup_Click"
                    Visibility="{x:Bind ViewModel.IsDone, Mode=OneWay,
                                  Converter={StaticResource BoolToVisibility}}"/>
            <Button Content="Go to Dashboard"
                    Click="Dashboard_Click"/>
        </StackPanel>
    </Grid>
</Page>
