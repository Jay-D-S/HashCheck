<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HashCheck.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Margin="24">
        <StackPanel Spacing="20" MaxWidth="600">
            <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

            <!-- Default storage path -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Header="Default .hash storage folder"
                         Text="{x:Bind ViewModel.DefaultHashStoragePath, Mode=TwoWay}"
                         PlaceholderText="Select a folder..."/>
                <Button Grid.Column="1" Content="Browse" VerticalAlignment="Bottom"
                        Margin="8,0,0,0" Click="BrowseStorage_Click"/>
            </Grid>

            <!-- Reminder days -->
            <NumberBox Header="Default reminder interval (days)"
                       Value="{x:Bind ViewModel.DefaultReminderDays, Mode=TwoWay}"
                       Minimum="1" Maximum="3650" SpinButtonPlacementMode="Inline"/>

            <!-- Algorithm -->
            <ComboBox Header="Default hash algorithm"
                      ItemsSource="{x:Bind ViewModel.AlgorithmNames}"
                      SelectedIndex="{x:Bind ViewModel.DefaultAlgorithmIndex, Mode=TwoWay}"/>

            <!-- Autoscan -->
            <ToggleSwitch Header="Autoscan new files after validation (default)"
                          IsOn="{x:Bind ViewModel.DefaultAutoscan, Mode=TwoWay}"/>

            <!-- Autoscan attach prompt -->
            <ToggleSwitch Header="Prompt to schedule autoscan when media is attached"
                          IsOn="{x:Bind ViewModel.AutoscanPromptOnAttach, Mode=TwoWay}"/>

            <!-- Run at login -->
            <ToggleSwitch Header="Run at Windows login"
                          IsOn="{x:Bind ViewModel.RunAtLogin, Mode=TwoWay}"/>

            <!-- Concurrent validation -->
            <StackPanel Spacing="4">
                <ToggleSwitch Header="Run validations concurrently"
                              IsOn="{x:Bind ViewModel.RunValidationsConcurrently, Mode=TwoWay}"/>
                <TextBlock Text="When validating a media group, scan all online volumes at the same time. Turn off if multiple volumes share the same physical drive."
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Known locations -->
            <StackPanel Spacing="8">
                <TextBlock Text="Known .hash file locations to scan" FontWeight="SemiBold"/>
                <ListView x:Name="LocationsList"
                          ItemsSource="{x:Bind ViewModel.KnownHashLocations}"
                          SelectionMode="Single"
                          MaxHeight="150">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Add Location" Click="AddLocation_Click"/>
                    <Button Content="Remove Selected" Click="RemoveLocation_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- Save -->
            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
                <Button Content="Save Settings" Click="Save_Click"
                        Style="{ThemeResource AccentButtonStyle}"/>
                <TextBlock Text="{x:Bind ViewModel.SaveStatus, Mode=OneWay}"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
