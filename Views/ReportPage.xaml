<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HashCheck.Views.ReportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:HashCheck.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
            <TextBlock Text="Validation Report" Style="{ThemeResource TitleTextBlockStyle}"/>
            <Border x:Name="StatusBadge" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" FontWeight="Bold"/>
            </Border>
        </StackPanel>

        <!-- Summary -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Text="Media" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="MediaNameText" FontWeight="SemiBold"/>
                <TextBlock x:Name="TimestampText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,16,0">
                <TextBlock Text="Files Found / In Set" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="FilesFoundText"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="0,0,16,0">
                <TextBlock Text="Matching / Not Matching" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="MatchingText"/>
            </StackPanel>
            <StackPanel Grid.Column="3">
                <TextBlock Text="Missing / Errors / New" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="IssuesText"/>
            </StackPanel>
        </Grid>

        <!-- Details -->
        <ScrollViewer Grid.Row="2">
            <StackPanel Spacing="16">
                <!-- Not Matching -->
                <StackPanel x:Name="NotMatchingPanel">
                    <TextBlock Text="Not Matching" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,4"/>
                    <ListView x:Name="NotMatchingList" MaxHeight="200"
                              SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- Missing -->
                <StackPanel x:Name="MissingPanel">
                    <TextBlock Text="Missing" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,4"/>
                    <ListView x:Name="MissingList" MaxHeight="200" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- Errors -->
                <StackPanel x:Name="ErrorsPanel">
                    <TextBlock Text="Errors" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,4"/>
                    <ListView x:Name="ErrorsList" MaxHeight="200" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- New files -->
                <StackPanel x:Name="NewFilesPanel">
                    <TextBlock Text="New Files (not in hash set)" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,4"/>
                    <ListView x:Name="NewFilesList" MaxHeight="200" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <Button Content="Export HTML" Click="ExportHtml_Click"/>
            <Button Content="Export CSV" Click="ExportCsv_Click"/>
            <Button Content="Re-create Hash Set" Click="ReCreate_Click"/>
            <Button Content="Back" Click="BackToDashboard_Click"/>
        </StackPanel>
    </Grid>
</Page>
