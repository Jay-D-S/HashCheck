<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HashCheck.Views.RepairPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:HashCheck.ViewModels"
    xmlns:conv="using:HashCheck.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Repair Media Group"
                   Style="{ThemeResource TitleTextBlockStyle}"
                   Margin="0,0,0,4"/>

        <!-- Subtitle: media name + phase indicator -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <TextBlock Text="{x:Bind ViewModel.MediaName, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock x:Name="PhaseLabel"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontStyle="Italic"/>
        </StackPanel>

        <!-- Phase content area -->
        <Grid Grid.Row="2">

            <!-- Phase 1: Validating — one card per online volume (same pattern as ValidatePage) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{x:Bind ViewModel.IsValidating, Mode=OneWay,
                                       Converter={StaticResource BoolToVisibility}}">
                <ItemsControl x:Name="ValidationRowsPanel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ValidationRow">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="16,12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header: label + serial + status badge -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                                        <TextBlock Text="{x:Bind Label}"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind SerialNumber}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                CornerRadius="2" Padding="6,2">
                                            <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                                                       FontSize="11"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Scan root -->
                                    <TextBlock Grid.Row="1"
                                               Text="{x:Bind ScanRoot}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="11" Margin="0,0,0,8"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Progress bar -->
                                    <ProgressBar Grid.Row="2"
                                                 Value="{x:Bind ProgressPercent, Mode=OneWay}"
                                                 Maximum="100"
                                                 Visibility="{x:Bind IsActive, Mode=OneWay,
                                                              Converter={StaticResource BoolToVisibility}}"
                                                 Margin="0,0,0,4"/>

                                    <!-- Files / ETA -->
                                    <TextBlock Grid.Row="3"
                                               Text="{x:Bind ProgressText, Mode=OneWay}"
                                               Visibility="{x:Bind IsActive, Mode=OneWay,
                                                            Converter={StaticResource BoolToVisibility}}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="12" Margin="0,0,0,4"/>

                                    <!-- Current file / error -->
                                    <TextBlock Grid.Row="4"
                                               Text="{x:Bind CurrentFile, Mode=OneWay}"
                                               Visibility="{x:Bind IsActive, Mode=OneWay,
                                                            Converter={StaticResource BoolToVisibility}}"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Row="4"
                                               Text="{x:Bind ErrorMessage, Mode=OneWay}"
                                               Visibility="{x:Bind HasErrorMessage, Mode=OneWay,
                                                            Converter={StaticResource BoolToVisibility}}"
                                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                               FontSize="12" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Phase 2: Repairing -->
            <StackPanel VerticalAlignment="Center" Spacing="12"
                        Visibility="{x:Bind ViewModel.IsRepairing, Mode=OneWay,
                                     Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="Copying files from intact drives…"
                           Style="{ThemeResource SubtitleTextBlockStyle}"/>
                <ProgressBar Value="{x:Bind ViewModel.RepairProgressPercent, Mode=OneWay}"
                             Maximum="100" MinWidth="400" HorizontalAlignment="Left"/>
                <TextBlock x:Name="RepairCountText"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="12"/>
                <TextBlock Text="{x:Bind ViewModel.CurrentFile, Mode=OneWay}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="700"/>
            </StackPanel>

            <!-- Complete / Done -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{x:Bind ViewModel.IsDone, Mode=OneWay,
                                       Converter={StaticResource BoolToVisibility}}">
                <StackPanel Spacing="16">
                    <!-- Summary cards -->
                    <Grid x:Name="SummaryGrid" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Margin="0,0,8,0" CornerRadius="4" Padding="12,10"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Repaired" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                <TextBlock x:Name="RepairedCountText" FontSize="22" FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Margin="0,0,8,0" CornerRadius="4" Padding="12,10"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Unrecoverable" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                <TextBlock x:Name="UnrecoverableCountText" FontSize="22" FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Margin="0,0,8,0" CornerRadius="4" Padding="12,10"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Read-only skipped" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                <TextBlock x:Name="SkippedCountText" FontSize="22" FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" CornerRadius="4" Padding="12,10"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Failed" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                <TextBlock x:Name="FailedCountText" FontSize="22" FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- No corruption found message -->
                    <TextBlock x:Name="NothingToRepairText"
                               Text="No corrupted files were found — all drives passed validation."
                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                               FontSize="14" Visibility="Collapsed"/>

                    <!-- Cancelled / failed message -->
                    <InfoBar x:Name="StatusInfoBar"
                             IsOpen="False" IsClosable="False"
                             Margin="0,0,0,4"/>

                    <!-- Repaired list -->
                    <StackPanel x:Name="RepairedPanel" Visibility="Collapsed">
                        <TextBlock Text="Repaired" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,4"/>
                        <ListView x:Name="RepairedList" MaxHeight="200" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Cascadia Code,Consolas,monospace"
                                               FontSize="12" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <!-- Unrecoverable list -->
                    <StackPanel x:Name="UnrecoverablePanel" Visibility="Collapsed">
                        <TextBlock Text="Unrecoverable — no intact copy found on any online drive"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,4"/>
                        <ListView x:Name="UnrecoverableList" MaxHeight="200" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Cascadia Code,Consolas,monospace"
                                               FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <!-- Read-only skipped list -->
                    <StackPanel x:Name="SkippedPanel" Visibility="Collapsed">
                        <TextBlock Text="Read-only drives — could not write repair"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,4"/>
                        <ListView x:Name="SkippedList" MaxHeight="200" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Cascadia Code,Consolas,monospace"
                                               FontSize="12" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <!-- Failed list -->
                    <StackPanel x:Name="FailedPanel" Visibility="Collapsed">
                        <TextBlock Text="Failed" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,4"/>
                        <ListView x:Name="FailedList" MaxHeight="200" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Cascadia Code,Consolas,monospace"
                                               FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Action bar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <Button Content="Cancel"
                    Click="Cancel_Click"
                    IsEnabled="{x:Bind ViewModel.CanCancel, Mode=OneWay}"/>
            <Button Content="Validate Again"
                    Click="ValidateAgain_Click"
                    Style="{ThemeResource AccentButtonStyle}"
                    Visibility="{x:Bind ViewModel.IsComplete, Mode=OneWay,
                                 Converter={StaticResource BoolToVisibility}}"
                    ToolTipService.ToolTip="Run a fresh validation to confirm repairs succeeded."/>
            <Button Content="Back"
                    Click="Back_Click"/>
        </StackPanel>
    </Grid>
</Page>
