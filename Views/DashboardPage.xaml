<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HashCheck.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:HashCheck.ViewModels"
    xmlns:conv="using:HashCheck.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:BoolToOnlineBrushConverter x:Key="BoolToOnlineBrushConverter"/>
        <Style x:Key="SortHeaderStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                             To="0.65" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                             To="0.45" Duration="0"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              FontWeight="{TemplateBinding FontWeight}"
                                              Foreground="{TemplateBinding Foreground}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Dashboard" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

        <!-- Banner shown when a validation is running in the background -->
        <InfoBar x:Name="ActiveValidationBar"
                 Grid.Row="1"
                 IsOpen="False"
                 IsClosable="False"
                 Severity="Informational"
                 Title="Validation in progress"
                 Message="A validation is running in the background."
                 Margin="0,0,0,8">
            <InfoBar.ActionButton>
                <Button Content="Return to validation" Click="ReturnToValidation_Click"/>
            </InfoBar.ActionButton>
        </InfoBar>

        <!-- Column headers -->
        <Grid Grid.Row="2" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"/>
            <Button x:Name="SortMedia"        Grid.Column="1" Content="Media"        Tag="Media"        Style="{StaticResource SortHeaderStyle}" Click="SortHeader_Click"/>
            <Button x:Name="SortDescription"  Grid.Column="2" Content="Description"  Tag="Description"  Style="{StaticResource SortHeaderStyle}" Click="SortHeader_Click"/>
            <Button x:Name="SortFiles"        Grid.Column="3" Content="Files"        Tag="Files"        Style="{StaticResource SortHeaderStyle}" Click="SortHeader_Click"/>
            <Button x:Name="SortSize"         Grid.Column="4" Content="Size"         Tag="Size"         Style="{StaticResource SortHeaderStyle}" Click="SortHeader_Click"/>
            <Button x:Name="SortCreated"      Grid.Column="5" Content="Created"      Tag="Created"      Style="{StaticResource SortHeaderStyle}" Click="SortHeader_Click"/>
            <Button x:Name="SortLastVerified" Grid.Column="6" Content="Last Verified" Tag="LastVerified" Style="{StaticResource SortHeaderStyle}" Click="SortHeader_Click"/>
            <Button x:Name="SortStatus"       Grid.Column="7" Content="Status"       Tag="Status"       Style="{StaticResource SortHeaderStyle}" Click="SortHeader_Click"/>
            <Button x:Name="SortAvailable"    Grid.Column="8" Content="Available"    Tag="Available"    Style="{StaticResource SortHeaderStyle}" Click="SortHeader_Click"/>
            <Button x:Name="SortNextDue"      Grid.Column="9" Content="Next Due"     Tag="NextDue"      Style="{StaticResource SortHeaderStyle}" Click="SortHeader_Click"/>
        </Grid>

        <ListView
            Grid.Row="3"
            x:Name="ItemsList"
            ItemsSource="{x:Bind ViewModel.Items}"
            SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
            SelectionMode="Single"
            DoubleTapped="ItemsList_DoubleTapped">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="4,6"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:DashboardItem">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <!-- Colored availability dot -->
                        <TextBlock Grid.Column="0" Text="●" FontSize="10" VerticalAlignment="Center"
                                   Foreground="{x:Bind IsAnyVolumeOnline, Converter={StaticResource BoolToOnlineBrushConverter}}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind MediaName}"     TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind Description}"   TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="3" Text="{x:Bind FileCount}"     HorizontalAlignment="Right" Margin="0,0,16,0"/>
                        <TextBlock Grid.Column="4" Text="{x:Bind TotalBytes}"/>
                        <TextBlock Grid.Column="5" Text="{x:Bind DateCreated}"/>
                        <TextBlock Grid.Column="6" Text="{x:Bind LastValidated}"/>
                        <TextBlock Grid.Column="7" Text="{x:Bind Status}"/>
                        <TextBlock Grid.Column="8" Text="{x:Bind AvailabilityText}"
                                   Foreground="{x:Bind IsAnyVolumeOnline, Converter={StaticResource BoolToOnlineBrushConverter}}"/>
                        <TextBlock Grid.Column="9" Text="{x:Bind NextDue}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="3" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Visibility="{x:Bind ViewModel.StatusMessageVisibility, Mode=OneWay}"/>

        <!-- Action bar -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <Button Content="Validate"        Click="ValidateSelected_Click"
                    IsEnabled="{x:Bind ViewModel.HasSelectedItem, Mode=OneWay}"/>
            <Button Content="Re-create"       Click="ReCreateSelected_Click"
                    IsEnabled="{x:Bind ViewModel.HasSelectedItem, Mode=OneWay}"/>
            <Button Content="Register Mirror" Click="RegisterMirror_Click"
                    IsEnabled="{x:Bind ViewModel.HasSelectedItem, Mode=OneWay}"/>
            <Button Content="Open Location"   Click="OpenLocation_Click"
                    IsEnabled="{x:Bind ViewModel.HasSelectedItem, Mode=OneWay}"/>
            <Button Content="Remove"          Click="RemoveSelected_Click"
                    IsEnabled="{x:Bind ViewModel.HasSelectedItem, Mode=OneWay}"/>
            <Button Content="Refresh"         Click="Refresh_Click"/>
        </StackPanel>
    </Grid>
</Page>
