<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HashCheck.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:HashCheck.ViewModels"
    xmlns:conv="using:HashCheck.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:BoolToOnlineBrushConverter x:Key="BoolToOnlineBrushConverter"/>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Dashboard" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

        <!-- Column headers -->
        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"/>
            <TextBlock Grid.Column="1" Text="Media"        FontWeight="SemiBold"/>
            <TextBlock Grid.Column="2" Text="Description"  FontWeight="SemiBold"/>
            <TextBlock Grid.Column="3" Text="Files"        FontWeight="SemiBold"/>
            <TextBlock Grid.Column="4" Text="Size"         FontWeight="SemiBold"/>
            <TextBlock Grid.Column="5" Text="Created"      FontWeight="SemiBold"/>
            <TextBlock Grid.Column="6" Text="Last Verified" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="7" Text="Status"       FontWeight="SemiBold"/>
            <TextBlock Grid.Column="8" Text="Available"    FontWeight="SemiBold"/>
            <TextBlock Grid.Column="9" Text="Next Due"     FontWeight="SemiBold"/>
        </Grid>

        <ListView
            Grid.Row="2"
            x:Name="ItemsList"
            ItemsSource="{x:Bind ViewModel.Items}"
            SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
            SelectionMode="Single"
            DoubleTapped="ItemsList_DoubleTapped">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="4,6"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:DashboardItem">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <!-- Colored availability dot -->
                        <TextBlock Grid.Column="0" Text="●" FontSize="10" VerticalAlignment="Center"
                                   Foreground="{x:Bind IsAnyVolumeOnline, Converter={StaticResource BoolToOnlineBrushConverter}}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind MediaName}"     TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind Description}"   TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="3" Text="{x:Bind FileCount}"     HorizontalAlignment="Right" Margin="0,0,16,0"/>
                        <TextBlock Grid.Column="4" Text="{x:Bind TotalBytes}"/>
                        <TextBlock Grid.Column="5" Text="{x:Bind DateCreated}"/>
                        <TextBlock Grid.Column="6" Text="{x:Bind LastValidated}"/>
                        <TextBlock Grid.Column="7" Text="{x:Bind Status}"/>
                        <TextBlock Grid.Column="8" Text="{x:Bind AvailabilityText}"
                                   Foreground="{x:Bind IsAnyVolumeOnline, Converter={StaticResource BoolToOnlineBrushConverter}}"/>
                        <TextBlock Grid.Column="9" Text="{x:Bind NextDue}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="2" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Visibility="{x:Bind ViewModel.StatusMessageVisibility, Mode=OneWay}"/>

        <!-- Action bar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <Button Content="Validate"        Click="ValidateSelected_Click"
                    IsEnabled="{x:Bind ViewModel.HasSelectedItem, Mode=OneWay}"/>
            <Button Content="Re-create"       Click="ReCreateSelected_Click"
                    IsEnabled="{x:Bind ViewModel.HasSelectedItem, Mode=OneWay}"/>
            <Button Content="Register Mirror" Click="RegisterMirror_Click"
                    IsEnabled="{x:Bind ViewModel.HasSelectedItem, Mode=OneWay}"/>
            <Button Content="Open Location"   Click="OpenLocation_Click"
                    IsEnabled="{x:Bind ViewModel.HasSelectedItem, Mode=OneWay}"/>
            <Button Content="Remove"          Click="RemoveSelected_Click"
                    IsEnabled="{x:Bind ViewModel.HasSelectedItem, Mode=OneWay}"/>
            <Button Content="Refresh"         Click="Refresh_Click"/>
        </StackPanel>
    </Grid>
</Page>
