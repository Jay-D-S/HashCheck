<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HashCheck.Views.CreateHashPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Create Hash Set" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

        <!-- Step: Select Scope -->
        <Grid Grid.Row="1" Visibility="{x:Bind ViewModel.IsScopeStep, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Select drives and folders to protect:" Margin="0,0,0,8"/>
            <TreeView Grid.Row="1" x:Name="ScopeTree"
                      Expanding="ScopeTree_Expanding"
                      SelectionMode="None">
                <TreeView.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding Content.IsChecked}"
                                  IsThreeState="True"
                                  Content="{Binding Content.Name}"
                                  Checked="NodeCheckBox_StateChanged"
                                  Unchecked="NodeCheckBox_StateChanged"
                                  Indeterminate="NodeCheckBox_StateChanged"
                                  VerticalAlignment="Center"
                                  Padding="4,0"/>
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
            <Button Grid.Row="2" Content="Next →" Click="SelectScopeNext_Click"
                    HorizontalAlignment="Right" Margin="0,12,0,0" Style="{ThemeResource AccentButtonStyle}"/>
        </Grid>

        <!-- Step: Configure -->
        <ScrollViewer Grid.Row="1" Visibility="{x:Bind ViewModel.IsConfigureStep, Mode=OneWay}">
            <StackPanel Spacing="16" MaxWidth="500">
                <TextBox Header="Description (required)"
                         Text="{x:Bind ViewModel.Description, Mode=TwoWay}"
                         PlaceholderText="e.g. Wedding photos master archive"/>

                <ComboBox Header="Hash Algorithm"
                          ItemsSource="{x:Bind ViewModel.AlgorithmNames}"
                          SelectedIndex="{x:Bind ViewModel.AlgorithmIndex, Mode=TwoWay}"/>

                <NumberBox Header="Reminder Interval (days)"
                           Value="{x:Bind ViewModel.ReminderDays, Mode=TwoWay}"
                           Minimum="1" Maximum="3650" SpinButtonPlacementMode="Inline"/>

                <StackPanel>
                    <TextBlock Text="Filter Mode" Margin="0,0,0,4"/>
                    <RadioButton Content="Exclude matching files (typical)"
                                 IsChecked="{x:Bind ViewModel.FilterModeExclude, Mode=TwoWay}"/>
                    <RadioButton Content="Include only matching files"
                                 IsChecked="{x:Bind ViewModel.FilterModeInclude, Mode=TwoWay}"/>
                </StackPanel>

                <TextBox Header="Filter Patterns (one per line)"
                         Text="{x:Bind ViewModel.FilterPatterns, Mode=TwoWay}"
                         AcceptsReturn="True"
                         Height="120"
                         TextWrapping="Wrap"/>

                <CheckBox Content="Autoscan — add new files automatically after each validation"
                          IsChecked="{x:Bind ViewModel.Autoscan, Mode=TwoWay}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Header="Save .hash file to"
                             Text="{x:Bind ViewModel.StoragePath, Mode=TwoWay}"
                             PlaceholderText="Select a folder..."/>
                    <Button Grid.Column="1" Content="Browse" VerticalAlignment="Bottom"
                            Margin="8,0,0,0" Click="BrowseStorage_Click"/>
                </Grid>

                <TextBlock Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}"
                           Foreground="Red"
                           Visibility="{x:Bind ViewModel.ProgressMessageVisibility, Mode=OneWay}"/>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="← Back" Click="ConfigureBack_Click"/>
                    <Button Content="Start Hashing" Click="StartHashing_Click"
                            Style="{ThemeResource AccentButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Step: Progress -->
        <Grid Grid.Row="1" Visibility="{x:Bind ViewModel.IsProgressStep, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Hashing files..." FontSize="18" Margin="0,0,0,16"/>

            <ProgressBar Grid.Row="1"
                         Value="{x:Bind ViewModel.FilesProcessed, Mode=OneWay}"
                         Maximum="{x:Bind ViewModel.FilesTotal, Mode=OneWay}"
                         Margin="0,0,0,8"/>

            <TextBlock Grid.Row="2"
                       Text="{x:Bind ViewModel.ProgressFilesText, Mode=OneWay}"
                       Margin="0,0,0,4"/>

            <ProgressBar Grid.Row="3"
                         Value="{x:Bind ViewModel.BytesProcessedD, Mode=OneWay}"
                         Maximum="{x:Bind ViewModel.BytesTotalD, Mode=OneWay}"
                         Margin="0,0,0,8"/>

            <TextBlock Grid.Row="4"
                       Text="{x:Bind ViewModel.ProgressBytesText, Mode=OneWay}"
                       Margin="0,0,0,4"/>

            <TextBlock Grid.Row="5"
                       Text="{x:Bind ViewModel.CurrentFile, Mode=OneWay}"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
                <TextBlock Text="{x:Bind ViewModel.EtaText, Mode=OneWay}" VerticalAlignment="Center"/>
                <Button Content="Cancel" Click="Cancel_Click"
                        IsEnabled="{x:Bind ViewModel.CanCancel, Mode=OneWay}"/>
            </StackPanel>
        </Grid>

        <!-- Step: Done -->
        <StackPanel Grid.Row="1" Visibility="{x:Bind ViewModel.IsDoneStep, Mode=OneWay}"
                    Spacing="16" VerticalAlignment="Center" HorizontalAlignment="Center">
            <FontIcon Glyph="{x:Bind ViewModel.ResultIcon, Mode=OneWay}"
                      FontSize="48"
                      FontFamily="Segoe Fluent Icons"
                      Foreground="{x:Bind ViewModel.ResultIconBrush, Mode=OneWay}"/>
            <TextBlock Text="{x:Bind ViewModel.ResultMessage, Mode=OneWay}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       Style="{ThemeResource SubtitleTextBlockStyle}"/>
            <TextBlock Text="{x:Bind ViewModel.ResultFilePath, Mode=OneWay}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="WrapWholeWords"
                       MaxWidth="400"/>
            <Button Content="Go to Dashboard" Click="GoToDashboard_Click"
                    HorizontalAlignment="Center" Style="{ThemeResource AccentButtonStyle}"/>
            <Button Content="Create Another" Click="CreateAnother_Click"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
